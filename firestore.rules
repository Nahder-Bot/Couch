rules_version = '2';

// Couch — Phase 5 auth-aware rules with 30-day grace window.
//
// Design:
//   - Every mutation requires signed-in + family membership + valid attribution
//     (request.resource.data.actingUid == request.auth.uid).
//   - During the grace window (settings/auth.graceUntil > request.time) legacy
//     {memberId, memberName} writes without actingUid are still allowed, so
//     pre-auth clients keep working until the user upgrades.
//   - Two collections (invites, claimTokens) are server-only — no client R/W;
//     they're written and consumed by Cloud Functions via the admin SDK.
//   - Family-doc CREATE allowed to new groups with self-as-owner (Plan 06
//     submitFamily new-group path). UPDATE/DELETE are CF-only.
//   - Three narrow client-create branches for member docs (see that block
//     for the table). Plans 06 + 07 rely on these; a blanket write:false
//     would break them.

service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================================
    // Helpers
    // ==========================================================

    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // True iff /users/{uid}/groups/{familyCode} exists — the CF writes this
    // index on join, and claimMember keeps it in sync. isMemberOfFamily is
    // the one lookup we use throughout the rules file so the result is
    // cached per-request.
    function isMemberOfFamily(familyCode) {
      return signedIn() && exists(/databases/$(database)/documents/users/$(uid())/groups/$(familyCode));
    }

    function isOwner(familyCode) {
      return signedIn()
        && exists(/databases/$(database)/documents/families/$(familyCode))
        && get(/databases/$(database)/documents/families/$(familyCode)).data.ownerUid == uid();
    }

    // Grace window is active while settings/auth.graceUntil is in the future.
    // If /settings/auth doesn't exist yet, treat grace as OFF (secure default).
    function graceActive() {
      return exists(/databases/$(database)/documents/settings/auth)
        && get(/databases/$(database)/documents/settings/auth).data.graceUntil > request.time.toMillis();
    }

    // validAttribution: incoming write must carry the caller's actingUid.
    // If the write is on behalf of a managed sub-profile (managedMemberId set),
    // the caller must actually manage that sub — member.managedBy must equal
    // the caller's uid. This is what stops parent forgery attacks.
    //
    // Phase 15.1 / SEC-15-1-02: anchor `memberId` (and `managedMemberId` when
    // present) to '^m_[A-Za-z0-9_-]+$' so RE2 meta-characters can never be
    // injected into runtime regex constructions like the title-doc
    // `actingTupleKey` echo regex `(^|.*,)' + memberId + '(,.*|$)`. The anchor
    // requires the full-string shape `m_<word-char-or-dash>+` — `.`, `*`, `\\`,
    // and other meta-characters are NOT in the allowed character class
    // `[A-Za-z0-9_-]` (`-` is last so it's a literal, not a range operator).
    // Closes WR-02. Mirrors the pattern at firestore.rules tupleProgress
    // sub-rule for memberId-derived runtime regex inputs.
    function validAttribution(familyCode) {
      return isMemberOfFamily(familyCode)
        && request.resource.data.actingUid == uid()
        && request.resource.data.memberId is string
        && request.resource.data.memberId.matches('^m_[A-Za-z0-9_-]+$')
        && (
          !('managedMemberId' in request.resource.data)
          || (
            request.resource.data.managedMemberId is string
            && request.resource.data.managedMemberId.matches('^m_[A-Za-z0-9_-]+$')
            && get(/databases/$(database)/documents/families/$(familyCode)/members/$(request.resource.data.managedMemberId)).data.managedBy == uid()
          )
        );
    }

    // Legacy writes from pre-auth clients: they send {memberId, memberName}
    // without an actingUid. Allowed only while grace is active.
    function legacyGraceWrite() {
      return graceActive()
        && request.resource.data.memberId is string
        && !('actingUid' in request.resource.data);
    }

    // Shared attribution check used by most family subcollection writes.
    function attributedWrite(familyCode) {
      return validAttribution(familyCode) || legacyGraceWrite();
    }


    // ==========================================================
    // Settings (read-only surface for clients)
    // ==========================================================

    match /settings/{doc} {
      allow read: if true;
      allow write: if false;
    }


    // ==========================================================
    // Per-user group index (self-only)
    // ==========================================================

    // Top-level user doc — holds notificationPrefs (PUSH-02) + future per-user state.
    // Self-read/write only. Other users cannot read a peer's notification settings.
    match /users/{u} {
      allow read, write: if signedIn() && u == uid();
    }

    match /users/{u}/groups/{familyCode} {
      allow read, write: if signedIn() && u == uid();
    }

    // Any other per-user subtree is server-only.
    match /users/{u}/{path=**} {
      allow read, write: if signedIn() && u == uid();
    }


    // ==========================================================
    // Family doc
    // ==========================================================

    match /families/{familyCode} {
      allow read: if isMemberOfFamily(familyCode);

      // Client CREATE allowed ONLY when:
      //   1. the doc doesn't exist yet (fresh family code)
      //   2. the creator stamps themselves as ownerUid atomically
      // This is Plan 06's submitFamily new-group path.
      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/families/$(familyCode))
        && request.resource.data.ownerUid == uid();

      // Narrow client UPDATE: ANY member may change the picker field (Who-picks-tonight
      // rotation config). ownerUid / passwordHash / mode / code must NOT change — those
      // mutations still go through Cloud Functions. The diff check pins mutation scope to
      // the picker field only.
      //
      // Plan 09-07a (absorbs 05x-legacy-family-ownership-migration): additive branch for
      // the legacy self-claim CTA. A signed-in member may stamp ownerUid = their own uid
      // ONLY when the existing family doc has no ownerUid (first-write-wins). Nothing else
      // may change in the same write — the diff check scopes the mutation to ownerUid only.
      // Second caller after ownership is set will get permission-denied, which the client
      // UI handles gracefully (CTA hides via onSnapshot; toast flashes "just claimed").
      //
      // Phase 14 / DECI-14-06 (D-06): additive third branch for couchSeating writes from
      // js/app.js persistCouchSeating(). Shape: families/{code}.couchSeating = { [memberId]:
      // index } (per-member-keyed map of cushion positions). Carries writeAttribution()
      // spread (actingUid + memberId + memberName, optionally managedMemberId) — the
      // affectedKeys() allowlist below names couchSeating + the four attribution fields.
      // The attributedWrite() helper is reused for actor-uid enforcement (T-14.04-01
      // Tampering mitigation: a member cannot plant a fake claim by another member because
      // request.resource.data.actingUid must equal request.auth.uid).
      //
      // 14-10 (sketch 003 V5 redesign): the FOURTH branch below allows the new
      // couchInTonight shape from V5's roster-pill control. Both branches are
      // active during the migration window (one PWA cache cycle).
      allow update: if (
          isMemberOfFamily(familyCode)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['picker'])
        ) || (
          // Legacy ownership self-claim: no ownerUid exists, caller is auth'd + a member,
          // caller writes their own uid as ownerUid, and nothing else changes.
          isMemberOfFamily(familyCode)
          && !('ownerUid' in resource.data)
          && request.resource.data.ownerUid == uid()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ownerUid'])
        ) || (
          // D-06: couchSeating write from persistCouchSeating() — attribution-required.
          // 14-10 NOTE: this branch is LEGACY but kept active because persistCouchInTonight
          // still writes both shapes during the migration. Drop after one cache cycle.
          attributedWrite(familyCode)
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['couchSeating', 'actingUid', 'managedMemberId', 'memberId', 'memberName'])
        ) || (
          // 14-10 (DECI-14-06 redesign per sketch 003 V5): couchInTonight write —
          // attribution-required. Any family member can write any member's slot
          // (proxy-fill is a feature, not a bug — one operator marks family in).
          // Audit trail via proxyConfirmedBy field embedded in the per-member
          // payload (NOT in affectedKeys; it's nested inside couchInTonight).
          // The allowlist also names couchSeating because persistCouchInTonight
          // dual-writes both shapes for one PWA cache cycle. After the cycle
          // elapses, a follow-up plan will drop couchSeating from this allowlist
          // AND the third branch above.
          attributedWrite(familyCode)
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['couchInTonight', 'couchSeating', 'actingUid', 'managedMemberId', 'memberId', 'memberName'])
        ) || (
          // === Phase 15.1 / SEC-15-1-03 — tupleNames + coWatchPromptDeclined participant check ===
          // Closes F-OPEN-02. Replaces the Phase 15 / D-02 + REVIEW MEDIUM-9 5th
          // branch (which only allowlisted the top-level fields without peeking
          // into the nested map's affected keys).
          //
          // Requires Phase 15.1-01 writer-side stamping of actingTupleKey on:
          //   - setTupleName (js/app.js:8546)
          //   - cv15CoWatchPromptDecline (js/app.js:1063)
          // Mirrors the existing title-doc tupleProgress actingTupleKey echo+regex
          // pattern at firestore.rules tupleProgress sub-rule.
          //
          // Five-part check:
          //   (a) attribution baseline (validAttribution → SEC-15-1-02 anchor on memberId)
          //   (b) outer allowlist now includes 'actingTupleKey' alongside the
          //       original 6 fields
          //   (c) when either tupleNames OR coWatchPromptDeclined is touched,
          //       require actingTupleKey to be a string AND match a regex that
          //       includes the actor's memberId at a comma boundary; the
          //       outer regex `^[A-Za-z0-9_,-]+$` self-sanitizes the tupleKey
          //       so attackers can't inject RE2 metas into the inner regex.
          //   (d) tupleNames diff inner keys hasOnly([actingTupleKey])
          //   (e) coWatchPromptDeclined diff inner keys hasOnly([actingTupleKey])
          attributedWrite(familyCode)
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['tupleNames', 'coWatchPromptDeclined', 'actingTupleKey',
                        'actingUid', 'managedMemberId', 'memberId', 'memberName'])
          // (c) actingTupleKey echo + comma-boundary actor regex
          && (
            !(request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['tupleNames', 'coWatchPromptDeclined']))
            || (
              'actingTupleKey' in request.resource.data
              && request.resource.data.actingTupleKey is string
              && request.resource.data.actingTupleKey.matches('^[A-Za-z0-9_,-]+$')
              && request.resource.data.actingTupleKey.matches(
                   '(^|.*,)' +
                   (('managedMemberId' in request.resource.data && request.resource.data.managedMemberId is string)
                      ? request.resource.data.managedMemberId
                      : request.resource.data.memberId) +
                   '(,.*|$)'
                 )
            )
          )
          // (d) tupleNames diff inner keys must hasOnly [actingTupleKey]
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['tupleNames'])
            || (
              ('tupleNames' in request.resource.data ? request.resource.data.tupleNames : {})
                .diff('tupleNames' in resource.data ? resource.data.tupleNames : {})
                .affectedKeys()
                .hasOnly([request.resource.data.actingTupleKey])
            )
          )
          // (e) coWatchPromptDeclined diff inner keys must hasOnly [actingTupleKey]
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['coWatchPromptDeclined'])
            || (
              ('coWatchPromptDeclined' in request.resource.data ? request.resource.data.coWatchPromptDeclined : {})
                .diff('coWatchPromptDeclined' in resource.data ? resource.data.coWatchPromptDeclined : {})
                .affectedKeys()
                .hasOnly([request.resource.data.actingTupleKey])
            )
          )
        );

      allow delete: if false;


      // ========================================================
      // Members (three narrow client-create branches)
      // ========================================================

      // | Branch | Who | Condition | Use case |
      // |--------|-----|-----------|----------|
      // | A | Any signed-in user | family's ownerUid (after this batch) == self AND request data has uid == self AND NO managedBy | Plan 06 joinAsNew first-member bootstrap |
      // | B | Existing member | request data has NO uid AND managedBy == self | Plan 07 createSubProfile |
      // | C | Existing member | request data has uid == self AND NO managedBy | Plan 06 joinAsNew existing-device self-add |
      match /members/{memberId} {
        allow read: if isMemberOfFamily(familyCode);

        allow create: if signedIn() && (
          // Branch A — first-member bootstrap (family doc being created in same batch)
          (
            getAfter(/databases/$(database)/documents/families/$(familyCode)).data.ownerUid == uid()
            && request.resource.data.uid == uid()
            && !('managedBy' in request.resource.data)
          )
          // Branch B — sub-profile create by existing family member
          || (
            isMemberOfFamily(familyCode)
            && !('uid' in request.resource.data)
            && request.resource.data.managedBy == uid()
          )
          // Branch C — existing authed member adds a new self-uid member doc
          || (
            isMemberOfFamily(familyCode)
            && request.resource.data.uid == uid()
            && !('managedBy' in request.resource.data)
          )
        );

        // Self, owner, or parent-of-managed-sub may update.
        // Plus: during grace window, an authed user may OPPORTUNISTICALLY CLAIM
        // a uid-less legacy member doc by writing their own uid on it. This is
        // the migration path for pre-Phase-5 family members signing in for the
        // first time. After the grace window closes this branch disappears and
        // claims must go through the claimMember Cloud Function.
        allow update: if signedIn() && (
          resource.data.uid == uid()
          || isOwner(familyCode)
          || resource.data.managedBy == uid()
          || (
            graceActive()
            && !('uid' in resource.data)
            && request.resource.data.uid == uid()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid', 'claimedAt'])
          )
        );

        // Owner deletes anyone; a self-member can delete themselves (leave group).
        allow delete: if isOwner(familyCode)
          || (signedIn() && resource.data.uid == uid());
      }


      // ========================================================
      // Server-only surfaces (CFs use admin SDK → bypasses rules)
      // ========================================================
      //
      // ARCHITECTURE NOTE (Plan 09-07b, 2026-04-22):
      //   Guest-invite member docs (type:'guest', temporary:true, expiresAt,
      //   seenOnboarding:true) are NOT written by rules-evaluated client paths.
      //   They're written exclusively by Cloud Functions (`joinGroup`,
      //   `inviteGuest`, `claimMember`, `consumeGuestInvite`) via the admin
      //   SDK, which bypasses Firestore rules entirely. That's why you WILL
      //   NOT FIND a `temporary == true` branch in this file — by design.
      //
      //   When a future archaeologist asks "where's the rule that lets
      //   guests exist?", the answer is: there is none at the rules layer.
      //   The three client-create branches above (A/B/C) exist for
      //   signed-in member self-creation and sub-profile creation.
      //   Guest/temporary member creation is an admin-SDK-only path.
      //
      //   Seed `05x-guest-invite-redemption` originally hypothesized a
      //   `temporary == true` rules branch; Plan 05-07 built the feature
      //   with CF+admin-SDK instead, so that hypothesis never shipped.
      //   Plan 09-07b's pre-flight invariant grep was a false-positive
      //   and has been reframed to this documentation comment.

      match /invites/{inviteId} {
        allow read, write: if false;
      }

      match /claimTokens/{tokenId} {
        allow read, write: if false;
      }


      // ========================================================
      // Tonight sessions — votes + vetoes map
      // ========================================================

      match /sessions/{dateKey} {
        allow read: if isMemberOfFamily(familyCode);
        allow create, update: if attributedWrite(familyCode);
        // Midnight-reset deletion: owner any time, any member during grace.
        allow delete: if isOwner(familyCode) || (isMemberOfFamily(familyCode) && graceActive());
      }


      // ========================================================
      // Veto history audit trail
      // ========================================================

      match /vetoHistory/{vetoId} {
        allow read: if isMemberOfFamily(familyCode);
        allow create: if attributedWrite(familyCode);
        // A veto record can only be deleted by the user who recorded it
        // (post-grace enforcement uses actingUid; grace allows legacy memberId self-delete).
        allow delete: if isMemberOfFamily(familyCode) && (
          resource.data.actingUid == uid()
          || (graceActive() && resource.data.memberId is string)
        );
      }


      // ========================================================
      // Titles (catalog) + their comment subcollection
      // ========================================================
      // Phase 14 / DECI-14-01 (D-01): the new t.rewatchAllowedBy map
      // (shape: { [memberId]: timestamp }) is permitted by the existing
      // permissive update rule below — there is no affectedKeys()
      // allowlist on title updates, so any new top-level field added by
      // an attributed family-member write is accepted. Mirrors the
      // existing t.queues / t.votes / t.ratings / t.progress / t.diary
      // per-member-keyed maps. Re-evaluate this comment if title updates
      // ever get tightened to a hasOnly([...]) allowlist; rewatchAllowedBy
      // would need to be added to that list at the same time.
      //
      // Title-doc updates (Phase 15 — REVIEW HIGH-1 tightening, 2026-04-26):
      // Permissive baseline (allows attributed writes by any family member to
      // most fields like queues, votes, watched, ratings, progress) PLUS three
      // new sensitive Phase 15 fields gated with per-member field-level rules:
      //   1. tupleProgress.{tupleKey}  — actor memberId (or managedMemberId)
      //                                  MUST appear in comma-split tupleKey
      //   2. mutedShows.{memberId}     — memberId MUST equal acting memberId
      //                                  (or managedMemberId — cannot silence others)
      //   3. liveReleaseFiredFor.{epKey} — CLIENT WRITES DENIED; CF-only via
      //                                    admin SDK (which bypasses rules)
      // The per-member predicates short-circuit to TRUE when the diff doesn't
      // touch the gated field, so all Phase 1-14 paths (queues/votes/ratings/
      // progress/etc.) continue to write under the permissive baseline.
      //
      // Per Plan 15-01 Task 1.5 fallback note: the rules-language `where`
      // lambda predicate is not supported on Sets/Lists in the Firestore rules
      // expression language, so the tupleProgress branch uses the planner's
      // pre-approved fallback shape — restrict the diff to EXACTLY ONE
      // tupleKey at a time and require that key contain the acting member.
      // This matches the v1 client write pattern (writeTupleProgress writes
      // one tupleKey per call per 15-02 plan).
      //
      // Identity surface: memberId in the writeAttribution payload is the
      // canonical actor surface (m_<UID> prefixed; tuple keys + mutedShows
      // keys both use this convention). managedMemberId takes precedence when
      // the actor is proxy-acting on a managed sub-profile.

      match /titles/{titleId} {
        allow read: if isMemberOfFamily(familyCode);
        allow create: if attributedWrite(familyCode);
        allow update: if attributedWrite(familyCode)
          && (
            // === Phase 15 / REVIEW HIGH-1 — explicit DENY for liveReleaseFiredFor ===
            // Client must NOT write this field. CF admin SDK bypasses rules and
            // writes via tdoc.ref.update({[`liveReleaseFiredFor.${epKey}`]: ...})
            // in 15-06 watchpartyTick. Any client write attempt is rejected here.
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['liveReleaseFiredFor'])
          )
          && (
            // === Phase 15 / REVIEW HIGH-1 — per-tuple-key isolation for tupleProgress ===
            // Plan-15-01 deviation: the planner's per-key actor-membership check
            // required `affectedKeys().toList()[0].matches(...)` but rules.Set has
            // no `.toList()` accessor (verified in Firestore emulator 2026-04-27).
            // Implemented partial HIGH-1 mitigation:
            //   (a) bound the diff to EXACTLY ONE tupleKey per write
            //   (b) require the client to echo the written tupleKey in a sibling
            //       payload field `request.resource.data.actingTupleKey` so the
            //       rule can hasOnly-equality the diff'd key
            //   (c) regex-validate that the echoed key contains the actor memberId
            //       (anchored at start, end, or surrounded by commas — matches the
            //       sorted-comma-joined tupleKey shape from 15-02 helper).
            // Forward-contract for 15-02: writeTupleProgress() MUST stamp
            // `actingTupleKey: tupleKey` alongside the tupleProgress write.
            // Without this echo, the write is denied. mutedShows + liveReleaseFiredFor
            // are fully mitigated (no echo needed; their inner keys are static).
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['tupleProgress'])
            || (
              request.resource.data.tupleProgress is map
              && request.resource.data.tupleProgress
                   .diff('tupleProgress' in resource.data ? resource.data.tupleProgress : {})
                   .affectedKeys().size() == 1
              && 'actingTupleKey' in request.resource.data
              && request.resource.data.actingTupleKey is string
              && request.resource.data.tupleProgress
                   .diff('tupleProgress' in resource.data ? resource.data.tupleProgress : {})
                   .affectedKeys()
                   .hasOnly([request.resource.data.actingTupleKey])
              && request.resource.data.actingTupleKey
                   .matches(
                     '(^|.*,)' +
                     (('managedMemberId' in request.resource.data && request.resource.data.managedMemberId is string)
                        ? request.resource.data.managedMemberId
                        : request.resource.data.memberId) +
                     '(,.*|$)'
                   )
            )
          )
          && (
            // === Phase 15 / REVIEW HIGH-1 — per-member mutedShows isolation ===
            // mutedShows.{memberId} writes/deletes only allowed when the inner
            // memberId matches the actor's memberId payload (or managedMemberId
            // when proxy-acting). diff().affectedKeys() returns the inner-map
            // keys being touched — every one must equal the actor's id.
            // `'X' in resource.data` guards property access against missing-field
            // errors for first-time writes (existing doc may not have mutedShows yet).
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['mutedShows'])
            || (
              ('mutedShows' in request.resource.data ? request.resource.data.mutedShows : {})
                .diff('mutedShows' in resource.data ? resource.data.mutedShows : {})
                .affectedKeys()
                .hasOnly([
                  ('managedMemberId' in request.resource.data && request.resource.data.managedMemberId is string)
                    ? request.resource.data.managedMemberId
                    : request.resource.data.memberId
                ])
            )
          )
          && (
            // === Phase 15.1 / SEC-15-1-01 — per-member progress isolation ===
            // Mirrors the mutedShows pattern; closes F-OPEN-01.
            // The actor (auth.uid via memberId or managedMemberId proxy) MUST own the
            // single touched inner key. Requires Phase 15.1-01 dotted-path writers
            // (writeMemberProgress / clearMemberProgress / Trakt-sync ingest) so the
            // diff exposes a single inner key rather than a full-map merge.
            // `'progress' in resource.data ? ... : {}` property-existence guards are
            // mandatory — bare resource.data.progress errors when the doc has no
            // progress field yet (first-write case).
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['progress'])
            || (
              request.resource.data.progress is map
              && ('progress' in request.resource.data ? request.resource.data.progress : {})
                   .diff('progress' in resource.data ? resource.data.progress : {})
                   .affectedKeys()
                   .hasOnly([
                     ('managedMemberId' in request.resource.data && request.resource.data.managedMemberId is string)
                       ? request.resource.data.managedMemberId
                       : request.resource.data.memberId
                   ])
            )
          );
        allow delete: if isMemberOfFamily(familyCode);

        match /comments/{commentId} {
          allow read: if isMemberOfFamily(familyCode);
          allow create, update: if attributedWrite(familyCode);
          allow delete: if isMemberOfFamily(familyCode) && (
            resource.data.actingUid == uid()
            || isOwner(familyCode)
            || (graceActive() && resource.data.memberId is string)
          );
        }
      }


      // ========================================================
      // Activity feed
      // ========================================================

      match /activity/{activityId} {
        allow read: if isMemberOfFamily(familyCode);
        allow create, update: if attributedWrite(familyCode);
        allow delete: if isOwner(familyCode);
      }


      // ========================================================
      // Lists (watchlist, recaps, etc.)
      // ========================================================

      match /lists/{listId} {
        allow read: if isMemberOfFamily(familyCode);
        allow create, update: if attributedWrite(familyCode);
        allow delete: if isMemberOfFamily(familyCode) && (
          resource.data.actingUid == uid()
          || isOwner(familyCode)
          || (graceActive() && resource.data.memberId is string)
        );
      }


      // ========================================================
      // Watchparties
      // ========================================================

      match /watchparties/{wpId} {
        allow read: if isMemberOfFamily(familyCode);
        allow create, update: if attributedWrite(familyCode);
        allow delete: if isOwner(familyCode) || (isMemberOfFamily(familyCode) && graceActive());
      }


      // ========================================================
      // Couch pings — Phase 15.4 / F-W-1 path A
      // ========================================================
      // Ephemeral mailbox: client (V5 roster long-press in js/app.js sendCouchPing) writes a
      // doc here; the onCouchPingFire CF (queuenight/functions/index.js) fans out a single
      // push to the recipient via sendToMembers + then admin-SDK deletes the doc. Doc shape:
      //   { senderId, senderName, recipientId, createdAt, ...writeAttribution() fields }
      // Rules: family member can CREATE their own ping (senderId == self via validAttribution +
      // recipientId anchored to '^m_[A-Za-z0-9_-]+$' to defang regex meta). Family members
      // can READ (so a future "you got pinged" inbox UI is reachable) but cannot UPDATE or
      // DELETE — the CF owns lifecycle. Mirrors the SEC-15-1-02 anchor pattern from
      // validAttribution for the new recipientId field which is NOT covered by the helper.

      match /couchPings/{pingId} {
        allow read: if isMemberOfFamily(familyCode);
        allow create: if attributedWrite(familyCode)
          && request.resource.data.senderId is string
          && request.resource.data.senderId.matches('^m_[A-Za-z0-9_-]+$')
          && request.resource.data.recipientId is string
          && request.resource.data.recipientId.matches('^m_[A-Za-z0-9_-]+$')
          && request.resource.data.senderId == request.resource.data.memberId;
        // No client update path — single-shot doc, deleted by CF after fan-out.
        allow update: if false;
        // No client delete — CF (admin SDK) bypasses rules to clean up after delivery.
        allow delete: if false;
      }


      // ========================================================
      // Intents — Phase 8 Watch-Intent Flows + Phase 14 Decision Ritual (D-09 / DR-1)
      // ========================================================
      // Four flow types share this subcollection (DR-1: extend, do not fork):
      //   - tonight_at_time, watch_this_title  (Phase 8 legacy, preserved verbatim)
      //   - rank-pick (Flow A — group rank-pick), nominate (Flow B — solo nominate)
      // Writes fall into disjoint update branches to keep attacker surface narrow while
      // allowing every family member to RSVP on their own behalf and any member to
      // detect & write the open→matched transition (client-side threshold detection
      // per 08-CONTEXT D-07, idempotent under races via status recheck).
      // Phase 14 additions: counterChainDepth bound + counter-chain bump branch (D-07.6 cap=3),
      // convert branch widened to allow open → converted (Flow A direct convert).

      match /intents/{intentId} {
        allow read: if isMemberOfFamily(familyCode);

        // Create: family member creates their own intent. Must stamp createdBy + status=open.
        // Type enum widened from 2 → 4 values per D-09 / DR-1.
        // counterChainDepth (when present) bounded to 0..3 per D-07.6 cap.
        allow create: if attributedWrite(familyCode)
          && request.resource.data.status == 'open'
          && (request.resource.data.type == 'tonight_at_time'
              || request.resource.data.type == 'watch_this_title'
              || request.resource.data.type == 'rank-pick'
              || request.resource.data.type == 'nominate')
          && (!('counterChainDepth' in request.resource.data)
              || (request.resource.data.counterChainDepth >= 0
                  && request.resource.data.counterChainDepth <= 3));

        // Update — five disjoint branches (4 legacy preserved + 1 new for counter-chain):
        //   (1) RSVP: any family member writes/clears their own rsvps slot + writeAttribution fields
        //   (2) Cancel: creator transitions status → 'cancelled'
        //   (3) Match-transition: any family member transitions status open → 'matched'
        //                         (client-side match detection writes this idempotently)
        //   (4) Convert: creator transitions status open OR matched → 'converted' (Flow A
        //                converts directly from open at quorum; Flow B/Phase 8 via matched).
        //   (5) Counter-chain bump: any family member submits a counter (atomic with their RSVP),
        //                          incrementing counterChainDepth by exactly 1, capped at 3.
        allow update: if attributedWrite(familyCode) && (
          // (1) RSVP branch — only rsvps map + attribution keys touched.
          //     Rules don't validate the inner rsvps[mid] shape; flow-specific shape
          //     (state vs value) is enforced client-side via createIntent / setIntentRsvp helpers.
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['rsvps', 'actingUid', 'managedMemberId', 'memberId', 'memberName'])

          // (2) Cancel branch — only the creator can cancel
          || (
            resource.data.createdByUid == uid()
            && request.resource.data.status == 'cancelled'
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'cancelledAt', 'actingUid', 'managedMemberId', 'memberId', 'memberName'])
          )

          // (3) Match transition — must cross open → matched
          || (
            resource.data.status == 'open'
            && request.resource.data.status == 'matched'
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'matchedAt', 'actingUid', 'managedMemberId', 'memberId', 'memberName'])
          )

          // (4) Convert transition — creator only. EXTENDED in Phase 14: allow
          //     open → converted (Flow A direct) in addition to matched → converted (Phase 8).
          //     convertedToWpId added to allowed key set alongside legacy convertedTo.
          || (
            (resource.data.status == 'matched' || resource.data.status == 'open')
            && request.resource.data.status == 'converted'
            && resource.data.createdByUid == uid()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'convertedTo', 'convertedToWpId', 'actingUid', 'managedMemberId', 'memberId', 'memberName'])
          )

          // (5) NEW (Phase 14 / D-07.6) — Counter-chain bump. Any family member can submit
          //     a counter, atomically updating their rsvps slot AND incrementing
          //     counterChainDepth by exactly 1. Cap at 3. Status must remain 'open'.
          || (
            resource.data.status == 'open'
            && (resource.data.counterChainDepth == null || resource.data.counterChainDepth < 3)
            && request.resource.data.counterChainDepth == (resource.data.counterChainDepth == null ? 1 : resource.data.counterChainDepth + 1)
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['rsvps', 'counterChainDepth', 'actingUid', 'managedMemberId', 'memberId', 'memberName'])
          )
        );

        // Never hard-delete — the intent doc is the Year-in-Review raw data (D-22/D-23).
        // Archival is done via status transitions (cancelled / expired / converted).
        allow delete: if false;
      }
    }
  }
}
